[general]
# Velocidad de caída de las barras (más bajo = más suave)
framerate = 60
autosens = 1
overshoot = 20
sensitivity = 100
bars = 0
bar_width = 2
bar_spacing = 1

[input]
# Cava suele encontrar el audio solo, pero si no, usa pipewire
method = pulse
source = auto

[output]
method = ncurses
style = stereo

[color]
# --- GRADIENTE "ISLA" (Azul -> Rosa) ---
gradient = 1
gradient_count = 6
gradient_color_1 = '#89b4fa'  # Azul Waybar
gradient_color_2 = '#cba6f7'  # Mauve
gradient_color_3 = '#f5c2e7'  # Rosa Suave
gradient_color_4 = '#eba0ac'  # Rosa Intenso
gradient_color_5 = '#f38ba8'  # Rojo Suave
gradient_color_6 = '#fab387'  # Naranja (Tope)

[smoothing]
# Suavizado para que no se vea "nervioso"
monstercat = 1
waves = 0
gravity = 100
ignore = 0
